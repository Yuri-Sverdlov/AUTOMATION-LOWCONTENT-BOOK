# .env.example — образец переменных окружения (идёт в git).
# Скопируй в .env и впиши реальный ключ. Файл .env уже в .gitignore — в репозиторий не попадёт.
#
# Провайдер по умолчанию — OpenRouter (один ключ открывает много моделей).
# Ключ берётся отсюда: https://openrouter.ai/  → API Keys.
OPENROUTER_API_KEY=

# На будущее (Вариант B / другие провайдеры) — раскомментируй нужное:
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# GOOGLE_API_KEY=
# (для локальной Ollama ключ не нужен — провайдер ollama в config/models.yaml)
